# 复制本文件为 .env 并填写真实值（.env 不应提交到 Git）

# OpenAI 兼容服务配置
API_KEY=
BASE_URL=https://api.openai.com/v1

# 模型 ID（填写你使用的服务端支持的模型名）
MODEL=

# 可选：Mini-Claw 引擎日志级别
# minimal | normal | verbose （也可用 0 | 1 | 2）
LM_LOG_LEVEL=normal

# 可选：开启调试日志（会在当前工作目录写入 lm_debug.log，可能包含敏感信息）
# 为空表示关闭；任意非空值表示开启
LM_DEBUG=

# 可选：最大工具调用轮次限制（默认 50，设为 0 表示无限制）
# 复杂任务可能需要更多轮次，可根据需要调整
LM_MAX_TURNS=50

