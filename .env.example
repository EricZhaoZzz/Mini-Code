# 复制本文件为 .env 并填写真实值（.env 不应提交到 Git）

# OpenAI 兼容服务配置
API_KEY=
BASE_URL=https://api.openai.com/v1

# 模型 ID（填写你使用的服务端支持的模型名）
MODEL=

# 可选：Mini-Code 引擎日志级别
# minimal | normal | verbose （也可用 0 | 1 | 2）
LM_LOG_LEVEL=normal

# 可选：开启调试日志（会在当前工作目录写入 lm_debug.log，可能包含敏感信息）
# 为空表示关闭；任意非空值表示开启
LM_DEBUG=

# 可选：最大工具调用轮次限制（默认 50，设为 0 表示无限制）
# 复杂任务可能需要更多轮次，可根据需要调整
LM_MAX_TURNS=50

# ============== Telegram Bot 配置 ==============
# 可选：Telegram Bot Token（从 @BotFather 获取）
TELEGRAM_BOT_TOKEN=

# 可选：允许使用 Bot 的用户 ID 列表（逗号分隔）
# 为空则允许所有用户访问
# 获取 User ID：发送任意消息给 @userinfobot
# 示例：TELEGRAM_ALLOWED_USERS=12345678,87654321
TELEGRAM_ALLOWED_USERS=

# 可选：开启 Telegram 调试模式（打印 User ID）
# 设置为任意非空值开启，用于获取你的 User ID
TELEGRAM_DEBUG=

